<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_fund_bill_form" model="ir.ui.view">
            <field name="name">nn.fund.bill.form</field>
            <field name="model">nn.fund.bill</field>
            <field name="arch" type="xml">
                <form string="Fund Bill">
                    <header>
                        <button name="action_post" string="Post Bill" type="object"
                            class="btn-primary" invisible="state != 'draft'"
                            groups="nn_fund_management.group_fund_finance_user"/>
                        <button name="action_cancel" string="Cancel" type="object"
                            class="btn-danger" invisible="state == 'cancelled'"/>
                        <field name="state" widget="statusbar"
                            statusbar_visible="draft,posted,cancelled"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1><field name="name" readonly="1"/></h1>
                        </div>
                        <group>
                            <group>
                                <field name="requisition_id" readonly="state != 'draft'"
                                    domain="[('state','=','approved')]"/>
                                <field name="project_id" readonly="1"/>
                                <field name="expense_head_id" readonly="1"/>
                                <field name="amount" readonly="state != 'draft'"/>
                                <field name="currency_id" invisible="1"/>
                            </group>
                            <group>
                                <field name="bill_date" readonly="state != 'draft'"/>
                                <field name="vendor" readonly="state != 'draft'"/>
                                <field name="company_id" groups="base.group_multi_company"/>
                            </group>
                        </group>
                        <field name="description" readonly="state != 'draft'" placeholder="Description..."/>
                        <field name="attachment_ids" widget="many2many_binary"/>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <record id="view_fund_bill_list" model="ir.ui.view">
            <field name="name">nn.fund.bill.list</field>
            <field name="model">nn.fund.bill</field>
            <field name="arch" type="xml">
                <tree string="Fund Bills" decoration-success="state=='posted'"
                    decoration-danger="state=='cancelled'">
                    <field name="name"/>
                    <field name="requisition_id"/>
                    <field name="project_id"/>
                    <field name="expense_head_id"/>
                    <field name="amount"/>
                    <field name="bill_date"/>
                    <field name="vendor"/>
                    <field name="state" widget="badge"
                        decoration-success="state=='posted'"
                        decoration-warning="state=='draft'"
                        decoration-danger="state=='cancelled'"/>
                </tree>
            </field>
        </record>

        <record id="view_fund_bill_search" model="ir.ui.view">
            <field name="name">nn.fund.bill.search</field>
            <field name="model">nn.fund.bill</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="requisition_id"/>
                    <field name="project_id"/>
                    <filter name="draft" string="Draft" domain="[('state','=','draft')]"/>
                    <filter name="posted" string="Posted" domain="[('state','=','posted')]"/>
                </search>
            </field>
        </record>

        <record id="action_fund_bill" model="ir.actions.act_window">
            <field name="name">Fund Bills</field>
            <field name="res_model">nn.fund.bill</field>
            <field name="view_mode">list,form</field>
        </record>
    </data>
</odoo>
