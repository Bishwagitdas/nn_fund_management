<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_fund_requisition_form" model="ir.ui.view">
            <field name="name">nn.fund.requisition.form</field>
            <field name="model">nn.fund.requisition</field>
            <field name="arch" type="xml">
                <form string="Fund Requisition">
                    <header>
                        <button name="action_submit" string="Submit" type="object"
                            class="btn-primary" invisible="state != 'draft'"/>
                        <button name="action_approve_gm" string="GM Approve" type="object"
                            class="btn-success" invisible="state != 'submitted'"
                            groups="nn_fund_management.group_fund_gm_approver"/>
                        <button name="action_approve_md" string="MD Approve" type="object"
                            class="btn-success" invisible="state != 'gm_approved'"
                            groups="nn_fund_management.group_fund_md_approver"/>
                        <button name="action_reject" string="Reject" type="object"
                            class="btn-danger"
                            invisible="state not in ['submitted','gm_approved']"/>
                        <button name="action_cancel" string="Cancel" type="object"
                            invisible="state in ['approved','rejected','cancelled','closed']"/>
                        <button name="action_close" string="Close Requisition" type="object"
                            class="btn-warning" invisible="state != 'approved'"/>
                        <button name="action_reset_draft" string="Reset to Draft" type="object"
                            invisible="state not in ['rejected','cancelled']"/>
                        <field name="state" widget="statusbar"
                            statusbar_visible="draft,submitted,gm_approved,approved,closed"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1><field name="name" readonly="1"/></h1>
                        </div>
                        <group>
                            <group>
                                <field name="requisition_type" readonly="state != 'draft'"/>
                                <field name="project_id" readonly="state != 'draft'"
                                    invisible="requisition_type != 'project'"/>
                                <field name="expense_head_id" readonly="state != 'draft'"
                                    invisible="requisition_type != 'expense_head'"/>
                                <field name="amount" readonly="state != 'draft'"/>
                                <field name="remaining_billable_amount" readonly="1"
                                    invisible="state != 'approved'"/>
                                <field name="total_billed" readonly="1"
                                    invisible="state != 'approved'"/>
                                <field name="currency_id" invisible="1"/>
                            </group>
                            <group>
                                <field name="request_date" readonly="state != 'draft'"/>
                                <field name="required_date" readonly="state != 'draft'"/>
                                <field name="requested_by" readonly="1"/>
                                <field name="gm_approver_id" readonly="1"
                                    invisible="not gm_approver_id"/>
                                <field name="md_approver_id" readonly="1"
                                    invisible="not md_approver_id"/>
                                <field name="company_id" groups="base.group_multi_company"/>
                            </group>
                        </group>
                        <field name="purpose" readonly="state != 'draft'"
                            placeholder="Purpose of requisition..."/>
                        <field name="attachment_ids" widget="many2many_binary"/>
                        <notebook>
                            <page string="Bills">
                                <field name="bill_ids" readonly="1">
                                    <tree>
                                        <field name="name"/>
                                        <field name="bill_date"/>
                                        <field name="amount"/>
                                        <field name="vendor"/>
                                        <field name="state" widget="badge"
                                            decoration-success="state=='posted'"
                                            decoration-danger="state=='cancelled'"/>
                                    </tree>
                                </field>
                            </page>
                            <page string="Approval History">
                                <field name="approval_history_ids" readonly="1">
                                    <tree>
                                        <field name="date"/>
                                        <field name="approval_level"/>
                                        <field name="approver_id"/>
                                        <field name="result" widget="badge"
                                            decoration-success="result=='approved'"
                                            decoration-danger="result=='rejected'"/>
                                        <field name="comment"/>
                                    </tree>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <record id="view_fund_requisition_list" model="ir.ui.view">
            <field name="name">nn.fund.requisition.list</field>
            <field name="model">nn.fund.requisition</field>
            <field name="arch" type="xml">
                <tree string="Fund Requisitions">
                    <field name="name"/>
                    <field name="project_id"/>
                    <field name="expense_head_id"/>
                    <field name="amount"/>
                    <field name="remaining_billable_amount"/>
                    <field name="request_date"/>
                    <field name="required_date"/>
                    <field name="requested_by"/>
                    <field name="state" widget="badge"
                        decoration-success="state in ['approved','closed']"
                        decoration-warning="state in ['submitted','gm_approved']"
                        decoration-danger="state in ['rejected','cancelled']"/>
                </tree>
            </field>
        </record>

        <record id="view_fund_requisition_search" model="ir.ui.view">
            <field name="name">nn.fund.requisition.search</field>
            <field name="model">nn.fund.requisition</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="project_id"/>
                    <field name="expense_head_id"/>
                    <filter name="pending" string="Pending Approval"
                        domain="[('state','in',['submitted','gm_approved'])]"/>
                    <filter name="approved" string="Approved"
                        domain="[('state','=','approved')]"/>
                    <filter name="my_requests" string="My Requests"
                        domain="[('requested_by','=',uid)]"/>
                </search>
            </field>
        </record>

        <record id="action_fund_requisition" model="ir.actions.act_window">
            <field name="name">Fund Requisitions</field>
            <field name="res_model">nn.fund.requisition</field>
            <field name="view_mode">list,form</field>
        </record>
    </data>
</odoo>
