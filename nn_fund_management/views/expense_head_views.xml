<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_expense_head_form" model="ir.ui.view">
            <field name="name">nn.expense.head.form</field>
            <field name="model">nn.expense.head</field>
            <field name="arch" type="xml">
                <form string="Expense Head">
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="code"/>
                                <field name="category"/>
                                <field name="company_id" groups="base.group_multi_company"/>
                                <field name="active"/>
                            </group>
                            <group>
                                <field name="currency_id"/>
                            </group>
                        </group>
                        <group string="Balance Summary" col="4">
                            <field name="total_allocated" readonly="1"/>
                            <field name="available_fund" readonly="1"/>
                            <field name="requisition_hold" readonly="1"/>
                            <field name="transfer_hold" readonly="1"/>
                            <field name="approved_unspent" readonly="1"/>
                            <field name="total_spent" readonly="1"/>
                            <field name="incoming_transfers" readonly="1"/>
                            <field name="outgoing_transfers" readonly="1"/>
                        </group>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <record id="view_expense_head_tree" model="ir.ui.view">
            <field name="name">nn.expense.head.tree</field>
            <field name="model">nn.expense.head</field>
            <field name="arch" type="xml">
                <tree string="Expense Heads">
                    <field name="name"/>
                    <field name="code"/>
                    <field name="category"/>
                    <field name="total_allocated"/>
                    <field name="available_fund"/>
                    <field name="total_spent"/>
                </tree>
            </field>
        </record>

        <record id="action_expense_head" model="ir.actions.act_window">
            <field name="name">Expense Heads</field>
            <field name="res_model">nn.expense.head</field>
            <field name="view_mode">tree,form</field>
        </record>
    </data>
</odoo>
