<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_fund_account_form" model="ir.ui.view">
            <field name="name">nn.fund.account.form</field>
            <field name="model">nn.fund.account</field>
            <field name="arch" type="xml">
                <form string="Fund Account">
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="code"/>
                                <field name="account_type"/>
                                <field name="company_id" groups="base.group_multi_company"/>
                                <field name="active"/>
                            </group>
                            <group>
                                <field name="currency_id"/>
                            </group>
                        </group>
                        <group string="Balance Summary" col="4">
                            <field name="total_received" readonly="1"/>
                            <field name="unassigned_balance" readonly="1"/>
                            <field name="on_hold_amount" readonly="1"/>
                            <field name="total_assigned" readonly="1"/>
                        </group>
                        <field name="notes" placeholder="Notes..."/>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <record id="view_fund_account_tree" model="ir.ui.view">
            <field name="name">nn.fund.account.tree</field>
            <field name="model">nn.fund.account</field>
            <field name="arch" type="xml">
                <tree string="Fund Accounts">
                    <field name="name"/>
                    <field name="code"/>
                    <field name="account_type"/>
                    <field name="currency_id"/>
                    <field name="total_received"/>
                    <field name="unassigned_balance"/>
                    <field name="on_hold_amount"/>
                    <field name="total_assigned"/>
                </tree>
            </field>
        </record>

        <record id="action_fund_account" model="ir.actions.act_window">
            <field name="name">Fund Accounts</field>
            <field name="res_model">nn.fund.account</field>
            <field name="view_mode">tree,form</field>
        </record>
    </data>
</odoo>
