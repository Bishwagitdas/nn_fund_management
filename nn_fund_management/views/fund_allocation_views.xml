<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_fund_allocation_form" model="ir.ui.view">
            <field name="name">nn.fund.allocation.form</field>
            <field name="model">nn.fund.allocation</field>
            <field name="arch" type="xml">
                <form string="Fund Allocation">
                    <header>
                        <button name="action_submit" string="Submit" type="object"
                            class="btn-primary" invisible="state != 'draft'"/>
                        <button name="action_approve_gm" string="GM Approve" type="object"
                            class="btn-success" invisible="state != 'submitted'"
                            groups="nn_fund_management.group_fund_gm_approver"/>
                        <button name="action_approve_md" string="MD Approve" type="object"
                            class="btn-success" invisible="state != 'gm_approved'"
                            groups="nn_fund_management.group_fund_md_approver"/>
                        <button name="action_reject" string="Reject" type="object"
                            class="btn-danger"
                            invisible="state not in ['submitted','gm_approved']"/>
                        <button name="action_cancel" string="Cancel" type="object"
                            invisible="state in ['approved','rejected','cancelled']"/>
                        <button name="action_reset_draft" string="Reset to Draft" type="object"
                            invisible="state not in ['rejected','cancelled']"/>
                        <field name="state" widget="statusbar"
                            statusbar_visible="draft,submitted,gm_approved,approved"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1><field name="name" readonly="1"/></h1>
                        </div>
                        <group>
                            <group>
                                <field name="fund_account_id" readonly="state != 'draft'"/>
                                <field name="allocation_type" readonly="state != 'draft'"/>
                                <field name="project_id" readonly="state != 'draft'"
                                    invisible="allocation_type != 'project'"/>
                                <field name="expense_head_id" readonly="state != 'draft'"
                                    invisible="allocation_type != 'expense_head'"/>
                                <field name="amount" readonly="state != 'draft'"/>
                                <field name="currency_id" invisible="1"/>
                            </group>
                            <group>
                                <field name="request_date" readonly="state != 'draft'"/>
                                <field name="requested_by" readonly="1"/>
                                <field name="submitted_by" readonly="1"
                                    invisible="not submitted_by"/>
                                <field name="gm_approver_id" readonly="1"
                                    invisible="not gm_approver_id"/>
                                <field name="md_approver_id" readonly="1"
                                    invisible="not md_approver_id"/>
                                <field name="company_id" groups="base.group_multi_company"/>
                            </group>
                        </group>
                        <field name="purpose" readonly="state != 'draft'"
                            placeholder="Purpose of allocation..."/>
                        <field name="attachment_ids" widget="many2many_binary"/>
                        <notebook>
                            <page string="Approval History">
                                <field name="approval_history_ids" readonly="1">
                                    <tree>
                                        <field name="date"/>
                                        <field name="approval_level"/>
                                        <field name="approver_id"/>
                                        <field name="result" widget="badge"
                                            decoration-success="result=='approved'"
                                            decoration-danger="result=='rejected'"/>
                                        <field name="comment"/>
                                        <field name="previous_state"/>
                                        <field name="new_state"/>
                                    </tree>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <record id="view_fund_allocation_tree" model="ir.ui.view">
            <field name="name">nn.fund.allocation.tree</field>
            <field name="model">nn.fund.allocation</field>
            <field name="arch" type="xml">
                <tree string="Fund Allocations"
                    decoration-success="state=='approved'"
                    decoration-warning="state in ['submitted','gm_approved']"
                    decoration-danger="state in ['rejected','cancelled']">
                    <field name="name"/>
                    <field name="fund_account_id"/>
                    <field name="project_id"/>
                    <field name="expense_head_id"/>
                    <field name="amount"/>
                    <field name="request_date"/>
                    <field name="requested_by"/>
                    <field name="state" widget="badge"
                        decoration-success="state=='approved'"
                        decoration-warning="state in ['submitted','gm_approved']"
                        decoration-danger="state in ['rejected','cancelled']"/>
                </tree>
            </field>
        </record>

        <record id="view_fund_allocation_search" model="ir.ui.view">
            <field name="name">nn.fund.allocation.search</field>
            <field name="model">nn.fund.allocation</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="fund_account_id"/>
                    <field name="project_id"/>
                    <field name="expense_head_id"/>
                    <filter name="pending" string="Pending Approval"
                        domain="[('state','in',['submitted','gm_approved'])]"/>
                    <filter name="approved" string="Approved"
                        domain="[('state','=','approved')]"/>
                    <filter name="my_requests" string="My Requests"
                        domain="[('requested_by','=',uid)]"/>
                    <group expand="0" string="Group By">
                        <filter name="group_state" string="Status"
                            context="{'group_by': 'state'}"/>
                        <filter name="group_account" string="Fund Account"
                            context="{'group_by': 'fund_account_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="action_fund_allocation" model="ir.actions.act_window">
            <field name="name">Fund Allocations</field>
            <field name="res_model">nn.fund.allocation</field>
            <field name="view_mode">tree,form</field>
        </record>
    </data>
</odoo>
