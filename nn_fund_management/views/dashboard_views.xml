<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Audit Log Views -->
        <record id="view_audit_log_list" model="ir.ui.view">
            <field name="name">nn.audit.log.list</field>
            <field name="model">nn.audit.log</field>
            <field name="arch" type="xml">
                <tree string="Audit Log" create="false" edit="false" delete="false">
                    <field name="date"/>
                    <field name="name"/>
                    <field name="user_id"/>
                    <field name="model_name"/>
                    <field name="record_ref"/>
                    <field name="previous_state"/>
                    <field name="new_state"/>
                    <field name="amount"/>
                    <field name="fund_account_id"/>
                    <field name="project_id"/>
                    <field name="expense_head_id"/>
                    <field name="comment"/>
                </tree>
            </field>
        </record>

        <record id="action_audit_log" model="ir.actions.act_window">
            <field name="name">Audit Log</field>
            <field name="res_model">nn.audit.log</field>
            <field name="view_mode">list</field>
        </record>

        <menuitem id="menu_audit_log"
            name="Audit Log"
            parent="menu_fund_reports"
            action="action_audit_log"
            sequence="10"/>

        <!-- Approval History Views -->
        <record id="view_approval_history_list" model="ir.ui.view">
            <field name="name">nn.approval.history.list</field>
            <field name="model">nn.approval.history</field>
            <field name="arch" type="xml">
                <tree string="Approval History" create="false" edit="false" delete="false">
                    <field name="date"/>
                    <field name="approval_level"/>
                    <field name="approver_id"/>
                    <field name="result" widget="badge"
                        decoration-success="result=='approved'"
                        decoration-danger="result=='rejected'"/>
                    <field name="amount"/>
                    <field name="comment"/>
                    <field name="previous_state"/>
                    <field name="new_state"/>
                </tree>
            </field>
        </record>

        <record id="action_approval_history" model="ir.actions.act_window">
            <field name="name">Approval History</field>
            <field name="res_model">nn.approval.history</field>
            <field name="view_mode">list</field>
        </record>

        <menuitem id="menu_approval_history"
            name="Approval History"
            parent="menu_fund_reports"
            action="action_approval_history"
            sequence="20"/>

        <!-- Fund Config Form -->
        <record id="view_fund_config_form" model="ir.ui.view">
            <field name="name">nn.fund.config.form</field>
            <field name="model">nn.fund.config</field>
            <field name="arch" type="xml">
                <form string="Fund Configuration">
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group string="Approvers">
                            <field name="gm_approver_ids" widget="many2many_tags"/>
                            <field name="md_approver_ids" widget="many2many_tags"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_fund_config_list" model="ir.ui.view">
            <field name="name">nn.fund.config.list</field>
            <field name="model">nn.fund.config</field>
            <field name="arch" type="xml">
                <tree string="Fund Configuration">
                    <field name="name"/>
                    <field name="company_id"/>
                    <field name="gm_approver_ids" widget="many2many_tags"/>
                    <field name="md_approver_ids" widget="many2many_tags"/>
                </tree>
            </field>
        </record>

        <record id="action_fund_config" model="ir.actions.act_window">
            <field name="name">Fund Configuration</field>
            <field name="res_model">nn.fund.config</field>
            <field name="view_mode">list,form</field>
        </record>

        <menuitem id="menu_fund_config"
            name="Fund Settings"
            parent="menu_fund_config_root"
            action="action_fund_config"
            sequence="10"/>

        <!-- Fund Dashboard -->
        <record id="view_fund_dashboard_form" model="ir.ui.view">
            <field name="name">nn.fund.dashboard.form</field>
            <field name="model">nn.fund.dashboard</field>
            <field name="arch" type="xml">
                <form string="Fund Management Dashboard" create="false" edit="false" delete="false">
                    <header>
                        <button name="action_refresh" string="Refresh" type="object" class="btn-primary"/>
                    </header>
                    <sheet>
                        <group string="Fund Summary" col="4">
                            <field name="total_received" readonly="1"/>
                            <field name="total_unassigned" readonly="1"/>
                            <field name="total_on_hold" readonly="1"/>
                            <field name="total_assigned" readonly="1"/>
                            <field name="total_spent" readonly="1"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                        <group string="Pending Approvals" col="4">
                            <field name="pending_allocations" readonly="1"/>
                            <field name="pending_requisitions" readonly="1"/>
                            <field name="pending_transfers" readonly="1"/>
                            <field name="total_pending_approvals" readonly="1"/>
                        </group>
                        <notebook>
                            <page string="Project Balances">
                                <field name="project_balance_ids" readonly="1">
                                    <tree>
                                        <field name="name"/>
                                        <field name="total_allocated"/>
                                        <field name="available_fund"/>
                                        <field name="requisition_hold"/>
                                        <field name="transfer_hold"/>
                                        <field name="total_spent"/>
                                    </tree>
                                </field>
                            </page>
                            <page string="Expense Head Balances">
                                <field name="expense_balance_ids" readonly="1">
                                    <tree>
                                        <field name="name"/>
                                        <field name="category"/>
                                        <field name="total_allocated"/>
                                        <field name="available_fund"/>
                                        <field name="total_spent"/>
                                    </tree>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_fund_dashboard" model="ir.actions.server">
            <field name="name">Fund Dashboard</field>
            <field name="model_id" ref="model_nn_fund_dashboard"/>
            <field name="state">code</field>
            <field name="code">action = model.get_dashboard_data()._get_dashboard_action()</field>
        </record>

        <menuitem id="menu_fund_dashboard"
            name="Dashboard"
            parent="menu_fund_management_root"
            action="action_fund_dashboard"
            sequence="5"/>
    </data>
</odoo>
