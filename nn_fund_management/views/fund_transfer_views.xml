<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_fund_transfer_form" model="ir.ui.view">
            <field name="name">nn.fund.transfer.form</field>
            <field name="model">nn.fund.transfer</field>
            <field name="arch" type="xml">
                <form string="Fund Transfer">
                    <header>
                        <button name="action_submit" string="Submit" type="object"
                            class="btn-primary" invisible="state != 'draft'"/>
                        <button name="action_approve_gm" string="GM Approve" type="object"
                            class="btn-success" invisible="state != 'submitted'"
                            groups="nn_fund_management.group_fund_gm_approver"/>
                        <button name="action_approve_md" string="MD Approve" type="object"
                            class="btn-success" invisible="state != 'gm_approved'"
                            groups="nn_fund_management.group_fund_md_approver"/>
                        <button name="action_reject" string="Reject" type="object"
                            class="btn-danger"
                            invisible="state not in ['submitted','gm_approved']"/>
                        <button name="action_cancel" string="Cancel" type="object"
                            invisible="state in ['approved','rejected','cancelled']"/>
                        <button name="action_reset_draft" string="Reset to Draft" type="object"
                            invisible="state not in ['rejected','cancelled']"/>
                        <field name="state" widget="statusbar"
                            statusbar_visible="draft,submitted,gm_approved,approved"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1><field name="name" readonly="1"/></h1>
                        </div>
                        <group>
                            <group string="Transfer Details">
                                <field name="transfer_type" readonly="state != 'draft'"/>
                                <field name="source_project_id" readonly="state != 'draft'"
                                    invisible="transfer_type not in ['project_project','project_expense']"/>
                                <field name="source_expense_head_id" readonly="state != 'draft'"
                                    invisible="transfer_type not in ['expense_project','expense_expense']"/>
                                <field name="destination_project_id" readonly="state != 'draft'"
                                    invisible="transfer_type not in ['project_project','expense_project']"/>
                                <field name="destination_expense_head_id" readonly="state != 'draft'"
                                    invisible="transfer_type not in ['project_expense','expense_expense']"/>
                                <field name="amount" readonly="state != 'draft'"/>
                                <field name="currency_id" invisible="1"/>
                            </group>
                            <group string="Request Info">
                                <field name="request_date" readonly="state != 'draft'"/>
                                <field name="requested_by" readonly="1"/>
                                <field name="gm_approver_id" readonly="1"
                                    invisible="not gm_approver_id"/>
                                <field name="md_approver_id" readonly="1"
                                    invisible="not md_approver_id"/>
                                <field name="company_id" groups="base.group_multi_company"/>
                            </group>
                        </group>
                        <field name="reason" readonly="state != 'draft'" placeholder="Reason for transfer..."/>
                        <field name="attachment_ids" widget="many2many_binary"/>
                        <notebook>
                            <page string="Approval History">
                                <field name="approval_history_ids" readonly="1">
                                    <tree>
                                        <field name="date"/>
                                        <field name="approval_level"/>
                                        <field name="approver_id"/>
                                        <field name="result" widget="badge"
                                            decoration-success="result=='approved'"
                                            decoration-danger="result=='rejected'"/>
                                        <field name="comment"/>
                                    </tree>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <record id="view_fund_transfer_list" model="ir.ui.view">
            <field name="name">nn.fund.transfer.list</field>
            <field name="model">nn.fund.transfer</field>
            <field name="arch" type="xml">
                <tree string="Fund Transfers">
                    <field name="name"/>
                    <field name="transfer_type"/>
                    <field name="source_project_id"/>
                    <field name="source_expense_head_id"/>
                    <field name="destination_project_id"/>
                    <field name="destination_expense_head_id"/>
                    <field name="amount"/>
                    <field name="request_date"/>
                    <field name="state" widget="badge"
                        decoration-success="state=='approved'"
                        decoration-warning="state in ['submitted','gm_approved']"
                        decoration-danger="state in ['rejected','cancelled']"/>
                </tree>
            </field>
        </record>

        <record id="view_fund_transfer_search" model="ir.ui.view">
            <field name="name">nn.fund.transfer.search</field>
            <field name="model">nn.fund.transfer</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="source_project_id"/>
                    <field name="destination_project_id"/>
                    <filter name="pending" string="Pending Approval"
                        domain="[('state','in',['submitted','gm_approved'])]"/>
                    <filter name="approved" string="Approved"
                        domain="[('state','=','approved')]"/>
                </search>
            </field>
        </record>

        <record id="action_fund_transfer" model="ir.actions.act_window">
            <field name="name">Fund Transfers</field>
            <field name="res_model">nn.fund.transfer</field>
            <field name="view_mode">list,form</field>
        </record>
    </data>
</odoo>
