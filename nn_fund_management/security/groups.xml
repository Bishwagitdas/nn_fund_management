<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="group_fund_user" model="res.groups">
            <field name="name">Fund User</field>
            <field name="category_id" ref="base.module_category_accounting_accounting"/>
            <field name="comment">Can create and view fund requests.</field>
        </record>

        <record id="group_fund_finance_user" model="res.groups">
            <field name="name">Finance User</field>
            <field name="category_id" ref="base.module_category_accounting_accounting"/>
            <field name="implied_ids" eval="[(4, ref('group_fund_user'))]"/>
            <field name="comment">Can confirm incoming funds and manage financial records.</field>
        </record>

        <record id="group_fund_gm_approver" model="res.groups">
            <field name="name">GM Approver</field>
            <field name="category_id" ref="base.module_category_accounting_accounting"/>
            <field name="implied_ids" eval="[(4, ref('group_fund_user'))]"/>
            <field name="comment">Can perform GM-level approvals.</field>
        </record>

        <record id="group_fund_md_approver" model="res.groups">
            <field name="name">MD Approver</field>
            <field name="category_id" ref="base.module_category_accounting_accounting"/>
            <field name="implied_ids" eval="[(4, ref('group_fund_user'))]"/>
            <field name="comment">Can perform MD-level approvals.</field>
        </record>

        <record id="group_fund_administrator" model="res.groups">
            <field name="name">Fund Administrator</field>
            <field name="category_id" ref="base.module_category_accounting_accounting"/>
            <field name="implied_ids" eval="[
                (4, ref('group_fund_finance_user')),
                (4, ref('group_fund_gm_approver')),
                (4, ref('group_fund_md_approver')),
            ]"/>
            <field name="comment">Full access to all fund management features.</field>
        </record>
    </data>
</odoo>
